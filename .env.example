DATABASE_URL=
DATABASE_MAX_CONNECTIONS=5
DATABASE_IDLE_TIMEOUT_SECONDS=20
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_MAX_LIFETIME_SECONDS=600
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
INTERNAL_BASE_URL=https://vetagent-internal.onrender.com
VET_ADMIN_PASSCODE=
VET_APP_ADMIN_PASSCODE=
VET_VETERINARIAN_PASSCODE=
# Set to disabled to reject built-in demo passcodes 246810 and 135790.
DEMO_ACCOUNTS=
HOSPITAL_NAME=Central Veterinary Hospital
APP_TIME_ZONE=America/Los_Angeles
MOCK_MODE=true
# AGENT_RUNTIME: `mock` (deterministic, no creds) or `google-adk` (live Gemini, auto-falls back to mock on error)
AGENT_RUNTIME=mock
# Live ADK reads GEMINI_API_KEY or GOOGLE_API_KEY (AI Studio key). Optional model override below.
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_ADK_MODEL=gemini-2.5-flash
GOOGLE_GENAI_USE_VERTEXAI=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
E2B_API_KEY=
# APIFY_API_TOKEN: read by the app. APIFY_TOKEN: read by the Apify CLI/skill — set to the SAME real token, not ${APIFY_API_TOKEN}.
APIFY_API_TOKEN=
APIFY_TOKEN=
# APIFY_PRICING_ACTOR_ID: optional. When unset, live pricing uses apify/google-search-scraper.
APIFY_PRICING_ACTOR_ID=

RESEND_API_KEY=
EMAIL_FROM=Central Veterinary Hospital <notifications@eepish.com>
DOCTOR_NOTIFICATION_EMAILS=doctor@example.com
TEST_NOTIFICATION_EMAIL=test@example.com
SMS_NOTIFICATION_RECIPIENTS=
TEST_SMS_NOTIFICATION_RECIPIENTS=5551234567@vtext.com
NOTIFICATION_MODE=disabled
NOTIFICATION_CHANNEL=email
MONTHLY_AGENT_EMAIL_MODE=disabled
MONTHLY_AGENT_EMAIL_RECIPIENTS=
MONTHLY_AGENT_EMAIL_SUBJECT=Central Veterinary Hospital monthly agent email
MONTHLY_AGENT_EMAIL_MESSAGE=This is the monthly VetAgent email path check.
DAILY_PRIORITY_SUMMARY_HOUR=18
CRON_SECRET=

{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.mjs", "eslint.config.mjs"],
      "project": ["scripts/*.mjs"]
    },
    "apps/internal": {
      "entry": [
        "app/**/page.tsx",
        "app/**/route.ts"
      ],
      "project": ["app/**/*.{ts,tsx}"]
    },
    "packages/db": {
      "entry": ["scripts/*.mjs"],
      "project": ["src/**/*.ts", "scripts/*.mjs"]
    }
  }
}

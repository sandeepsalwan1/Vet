{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": ["opensrc/**"],
  "workspaces": {
    ".": {
      "entry": ["scripts/*.mjs", "eslint.config.mjs"],
      "project": ["scripts/*.mjs"]
    },
    "apps/internal": {
      "entry": [
        "app/**/page.tsx",
        "app/**/route.ts"
      ],
      "project": ["app/**/*.{ts,tsx}", "components/**/*.{ts,tsx}", "lib/**/*.ts"],
      "ignoreDependencies": ["sharp"],
      "ignoreIssues": {
        "components/ui/**": ["exports", "types"]
      }
    },
    "packages/db": {
      "entry": ["scripts/*.mjs"],
      "project": ["src/**/*.ts", "scripts/*.mjs"]
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bugsFound",
    "fixesMade",
    "checksRun",
    "remainingRisk",
    "proofNeeded",
    "mergeRecommendation",
    "humanQuestion"
  ],
  "properties": {
    "bugsFound": {
      "type": "array",
      "items": { "type": "string" }
    },
    "fixesMade": {
      "type": "array",
      "items": { "type": "string" }
    },
    "checksRun": {
      "type": "array",
      "items": { "type": "string" }
    },
    "remainingRisk": { "enum": ["low", "medium", "high"] },
    "proofNeeded": { "enum": ["none", "CI", "UI", "GIF"] },
    "mergeRecommendation": {
      "enum": ["ready", "ready-human-review", "blocked"]
    },
    "humanQuestion": { "type": "string" }
  }
}
